  "info": {
    "_postman_id": "fe80ada0-f67e-4375-9b0a-8cfb7b110026",
    "name": "CMS Data at the Point of Care API (DPC)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Data at the Point of Care (DPC) fills gaps in patient history by delivering Medicare\nclaims data via HL7 FHIR Bulk Data Access to fee-for-service providers. Providers\nregister Practitioner, Organization, and Patient roster resources, then asynchronously\n$export ExplanationOfBenefit, Coverage, and Patient resources.\n\n\nContact Support:\n Name: DPC Support\n Email: dpcinfo@cms.hhs.gov",
      "type": "text/plain"
    }
  }
