  "info": {
    "_postman_id": "50fb9d45-e9bf-4db6-aec8-b8c504815abf",
    "name": "CMS Beneficiary FHIR Data Server (BFD)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Beneficiary FHIR Data (BFD) Server is the upstream HL7 FHIR R4 service that powers\nBlue Button 2.0, BCDA, AB2D, and DPC. BFD ingests claims from the CMS Chronic Conditions\nWarehouse (CCW). Access is limited to internal CMS systems and the four downstream\npeering applications.\n\n\nContact Support:\n Name: BFD Team",
      "type": "text/plain"
    }
  }
