  "info": {
    "_postman_id": "40b48b5a-fd08-4a70-86a9-7cd44d580788",
    "name": "CMS Beneficiary Claims Data API (BCDA)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "BCDA enables Medicare Shared Savings Program ACOs to retrieve bulk Medicare Parts A, B,\nand D claims data for assigned and assignable beneficiaries via the HL7 FHIR Bulk Data\nAccess (Flat FHIR) specification.\n\n\nContact Support:\n Name: BCDA Help\n Email: bcapi@cms.hhs.gov",
      "type": "text/plain"
    }
  }
